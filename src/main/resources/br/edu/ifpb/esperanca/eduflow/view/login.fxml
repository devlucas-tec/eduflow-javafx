<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="br.edu.ifpb.esperanca.eduflow.controller.LoginController"
           styleClass="login-root"
           stylesheets="@./styles/eduflow.css">

    <VBox alignment="CENTER">
        <VBox styleClass="login-card" spacing="13">

            <VBox alignment="CENTER" spacing="4">
                <Label text="EduFlow" styleClass="login-logo"/>
                <Label text="Sistema de Gerenciamento de Monitorias"
                       styleClass="login-tagline"/>
            </VBox>

            <Region styleClass="login-divider" maxWidth="Infinity"/>

            <VBox spacing="5">
                <Label text="E-mail Institucional" styleClass="field-label"/>
                <TextField fx:id="txtEmail"
                           promptText="seu.email@academico.ifpb.edu.br"
                           styleClass="text-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Senha" styleClass="field-label"/>
                <PasswordField fx:id="txtSenha"
                               promptText="Sua senha"
                               styleClass="password-field"/>
            </VBox>

            <Text fx:id="errorMessage" styleClass="label-error" visible="false"/>

            <Button fx:id="btnLogin" text="Entrar"
                    onAction="#handleLogin"
                    defaultButton="true"
                    styleClass="btn-primary"
                    maxWidth="Infinity">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </Button>

            <HBox alignment="CENTER">
                <Hyperlink text="Não tem conta? Cadastre-se"
                           onAction="#handleIrParaCadastro"
                           styleClass="hyperlink"/>
            </HBox>

        </VBox>
    </VBox>
</StackPane>
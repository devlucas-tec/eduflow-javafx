<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.esperanca.eduflow.controller.AlunoDashBoardController"
            styleClass="dashboard-root"
            stylesheets="@./styles/eduflow.css">

    <top>
        <HBox styleClass="topbar, topbar-aluno" alignment="CENTER_LEFT" spacing="12">
            <VBox>
                <Label text="EduFlow" styleClass="topbar-title"/>
                <Label text="Painel do Aluno" styleClass="topbar-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblBemVindo" styleClass="user-badge"/>
            <Button text="Sair" onAction="#handleLogout" styleClass="btn-sair"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-area" VBox.vgrow="ALWAYS">
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="main-container" VBox.vgrow="ALWAYS">

                <!-- Aba 1: Minhas Disciplinas -->
                <Tab text="Minhas Disciplinas">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">

                            <Label text="▸  Matriculado em" styleClass="label-section"/>
                            <TableView fx:id="tabelaMatriculadas" prefHeight="180"
                                       styleClass="table-view">
                                <columns>
                                    <TableColumn fx:id="colMatNome"     text="Disciplina" prefWidth="260"/>
                                    <TableColumn fx:id="colMatCodigo"   text="Código"     prefWidth="120"/>
                                    <TableColumn fx:id="colMatSemestre" text="Semestre"   prefWidth="120"/>
                                </columns>
                            </TableView>
                            <HBox>
                                <Button text="Cancelar Matrícula Selecionada"
                                        onAction="#handleCancelarMatricula"
                                        styleClass="btn-danger"/>
                            </HBox>

                            <Label text="▸  Disciplinas disponíveis" styleClass="label-section"/>
                            <TableView fx:id="tabelaDisponiveis" prefHeight="180"
                                       styleClass="table-view">
                                <columns>
                                    <TableColumn fx:id="colDispNome"     text="Disciplina" prefWidth="260"/>
                                    <TableColumn fx:id="colDispCodigo"   text="Código"     prefWidth="120"/>
                                    <TableColumn fx:id="colDispSemestre" text="Semestre"   prefWidth="120"/>
                                </columns>
                            </TableView>
                            <HBox>
                                <Button text="Matricular na Disciplina Selecionada"
                                        onAction="#handleMatricular"
                                        styleClass="btn-accent"/>
                            </HBox>

                            <Text fx:id="errorDisciplina"   styleClass="label-error"   visible="false"/>
                            <Text fx:id="successDisciplina" styleClass="label-success" visible="false"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- Aba 2: Agendar Monitoria -->
                <Tab text="Agendar Monitoria">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="12" style="-fx-padding: 20;">
                            <Label text="▸  Horários disponíveis" styleClass="label-section"/>
                            <TableView fx:id="tabelaAgendas" prefHeight="240"
                                       styleClass="table-view">
                                <columns>
                                    <TableColumn fx:id="colDisciplina" text="Disciplina"  prefWidth="180"/>
                                    <TableColumn fx:id="colHorario"   text="Horário"     prefWidth="260"/>
                                    <TableColumn fx:id="colLocal"     text="Local / Link" prefWidth="200"/>
                                    <TableColumn fx:id="colVagas"     text="Vagas"       prefWidth="80"/>
                                </columns>
                            </TableView>
                            <VBox spacing="5">
                                <Label text="Assunto / Dúvida" styleClass="field-label"/>
                                <TextArea fx:id="txtAssunto"
                                          promptText="Descreva sua dúvida..."
                                          prefHeight="80"
                                          styleClass="text-area"/>
                            </VBox>
                            <HBox>
                                <Button text="Confirmar Agendamento"
                                        onAction="#handleAgendar"
                                        styleClass="btn-accent"/>
                            </HBox>
                            <Text fx:id="errorMessage"   styleClass="label-error"   visible="false"/>
                            <Text fx:id="successMessage" styleClass="label-success" visible="false"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- Aba 3: Meus Agendamentos -->
                <Tab text="Meus Agendamentos">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="12" style="-fx-padding: 20;">
                            <Label text="▸  Histórico de agendamentos" styleClass="label-section"/>
                            <TableView fx:id="tabelaMeusAgendamentos" prefHeight="300"
                                       styleClass="table-view">
                                <columns>
                                    <TableColumn fx:id="colMeuStatus"        text="Status"                       prefWidth="130"/>
                                    <TableColumn fx:id="colMeuAssunto"       text="Assunto"                      prefWidth="220"/>
                                    <TableColumn fx:id="colMeuHorario"       text="Horário"                      prefWidth="160"/>
                                    <TableColumn fx:id="colMeuJustificativa" text="Justificativa do Cancelamento" prefWidth="240"/>
                                </columns>
                            </TableView>
                            <HBox>
                                <Button text="Cancelar Agendamento Selecionado"
                                        onAction="#handleCancelarAgendamento"
                                        styleClass="btn-danger"/>
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </VBox>
    </center>
</BorderPane>
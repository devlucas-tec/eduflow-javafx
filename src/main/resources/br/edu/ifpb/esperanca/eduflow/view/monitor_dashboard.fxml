<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.esperanca.eduflow.controller.MonitorDashBoardController"
            style="-fx-background-color: #F0F4F8;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #1A6B3C; -fx-padding: 15;">
            <Label fx:id="lblBemVindo" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Sair" onAction="#handleLogout"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 5;"/>
        </HBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 10;">

            <!-- ABA 1: Minhas Disciplinas (como aluno) -->
            <Tab text="Minhas Disciplinas">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Minhas Disciplinas" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="Matriculado em:" style="-fx-font-weight: bold; -fx-text-fill: #27AE60;"/>
                    <TableView fx:id="tabelaMatriculadas" prefHeight="160" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colMatNome" text="Disciplina" prefWidth="260"/>
                            <TableColumn fx:id="colMatCodigo" text="Código" prefWidth="120"/>
                            <TableColumn fx:id="colMatSemestre" text="Semestre" prefWidth="120"/>
                        </columns>
                    </TableView>
                    <Button text="Cancelar Matrícula Selecionada" onAction="#handleCancelarMatricula"
                            style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    <Label text="Disciplinas disponíveis:" style="-fx-font-weight: bold; -fx-text-fill: #2980B9;"/>
                    <TableView fx:id="tabelaDisponiveis" prefHeight="160" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDispNome" text="Disciplina" prefWidth="260"/>
                            <TableColumn fx:id="colDispCodigo" text="Código" prefWidth="120"/>
                            <TableColumn fx:id="colDispSemestre" text="Semestre" prefWidth="120"/>
                        </columns>
                    </TableView>
                    <Button text="Matricular na Disciplina Selecionada" onAction="#handleMatricular"
                            style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    <Text fx:id="errorDisciplina" fill="RED" visible="false"/>
                    <Text fx:id="successDisciplina" fill="GREEN" visible="false"/>
                </VBox>
            </Tab>

            <!-- ABA 2: Agendar Monitoria (como aluno) -->
            <Tab text="Agendar Monitoria">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Horários disponíveis:" style="-fx-font-weight: bold;"/>
                    <TableView fx:id="tabelaAgendas" prefHeight="220">
                        <columns>
                            <TableColumn fx:id="colDisciplina" text="Disciplina" prefWidth="180"/>
                            <TableColumn fx:id="colHorario" text="Horário" prefWidth="260"/>
                            <TableColumn fx:id="colLocal" text="Local / Link" prefWidth="180"/>
                            <TableColumn fx:id="colVagas" text="Vagas" prefWidth="70"/>
                        </columns>
                    </TableView>
                    <Label text="Assunto / Dúvida:" style="-fx-font-weight: bold;"/>
                    <TextArea fx:id="txtAssunto" promptText="Descreva sua dúvida..." prefHeight="70"/>
                    <Button text="Confirmar Agendamento" onAction="#handleAgendar"
                            style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    <Text fx:id="errorAgendamento" fill="RED" visible="false"/>
                    <Text fx:id="successAgendamento" fill="GREEN" visible="false"/>
                </VBox>
            </Tab>

            <!-- ABA 3: Meus Agendamentos (como aluno) -->
            <Tab text="Meus Agendamentos">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <TableView fx:id="tabelaMeusAgendamentos" prefHeight="300">
                        <columns>
                            <TableColumn fx:id="colMeuStatus" text="Status" prefWidth="150"/>
                            <TableColumn fx:id="colMeuAssunto" text="Assunto" prefWidth="300"/>
                            <TableColumn fx:id="colMeuHorario" text="Horário" prefWidth="200"/>
                        </columns>
                    </TableView>
                    <Button text="Cancelar Agendamento Selecionado" onAction="#handleCancelarAgendamento"
                            style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 5;"/>
                </VBox>
            </Tab>

            <!-- ABA 4: Minha Agenda de Monitoria -->
            <Tab text="Minha Agenda">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Meus Horários Cadastrados:" style="-fx-font-weight: bold;"/>
                    <TableView fx:id="tabelaMinhasAgendas" prefHeight="180">
                        <columns>
                            <TableColumn fx:id="colAgHorario" text="Horário" prefWidth="260"/>
                            <TableColumn fx:id="colAgLocal" text="Local / Link" prefWidth="200"/>
                            <TableColumn fx:id="colAgVagas" text="Vagas" prefWidth="80"/>
                        </columns>
                    </TableView>
                    <Label text="Cadastrar Novo Horário:" style="-fx-font-weight: bold; -fx-padding: 8 0 0 0;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cbDisciplina" promptText="Disciplina" prefWidth="200"/>
                        <DatePicker fx:id="dpData" promptText="Data" prefWidth="150"/>
                        <TextField fx:id="txtHoraInicio" promptText="Início (HH:mm)" prefWidth="110"/>
                        <TextField fx:id="txtHoraFim" promptText="Fim (HH:mm)" prefWidth="110"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtLocal" promptText="Sala física (RN10)" prefWidth="240"/>
                        <TextField fx:id="txtLink" promptText="Link videoconferência (RN10)" prefWidth="240"/>
                        <Label text="Vagas:"/>
                        <Spinner fx:id="spVagas" min="1" max="30" initialValue="5" prefWidth="80"/>
                    </HBox>
                    <Button text="Cadastrar Horário" onAction="#handleCadastrarAgenda"
                            style="-fx-background-color: #1A6B3C; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    <Text fx:id="errorMessage" fill="RED" visible="false"/>
                    <Text fx:id="successMessage" fill="GREEN" visible="false"/>
                </VBox>
            </Tab>

            <!-- ABA 5: Registrar Atendimentos -->
            <Tab text="Atendimentos">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Agendamentos pendentes de registro:" style="-fx-font-weight: bold;"/>
                    <TableView fx:id="tabelaAgendamentos" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="colAgdAluno" text="Aluno" prefWidth="180"/>
                            <TableColumn fx:id="colAgdAssunto" text="Assunto" prefWidth="260"/>
                            <TableColumn fx:id="colAgdStatus" text="Status" prefWidth="130"/>
                        </columns>
                    </TableView>
                    <CheckBox fx:id="chkPresenca" text="Aluno compareceu?"/>
                    <TextArea fx:id="txtConteudo" promptText="Conteúdo trabalhado (RN06)..." prefHeight="70"/>
                    <Button text="Registrar Atendimento" onAction="#handleRegistrarAtendimento"
                            style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-background-radius: 5;"/>
                </VBox>
            </Tab>

            <!-- ABA 6: Relatórios -->
            <Tab text="Relatórios">
                <VBox spacing="12" style="-fx-padding: 15;">
                    <Label text="Relatório de Monitoria" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Button text="Gerar Relatório" onAction="#handleGerarRelatorio"
                            style="-fx-background-color: #8E44AD; -fx-text-fill: white; -fx-background-radius: 5;"/>

                    <!-- Resumo numérico -->
                    <HBox spacing="20" style="-fx-padding: 8 0;">
                        <VBox alignment="CENTER" style="-fx-background-color: #D5F5E3; -fx-padding: 12; -fx-background-radius: 8;">
                            <Label text="Atendimentos" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblTotalAtendimentos" text="—" style="-fx-font-size: 22px; -fx-text-fill: #1A6B3C;"/>
                        </VBox>
                        <VBox alignment="CENTER" style="-fx-background-color: #FADBD8; -fx-padding: 12; -fx-background-radius: 8;">
                            <Label text="Faltas" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblTotalFaltas" text="—" style="-fx-font-size: 22px; -fx-text-fill: #E74C3C;"/>
                        </VBox>
                        <VBox alignment="CENTER" style="-fx-background-color: #D6EAF8; -fx-padding: 12; -fx-background-radius: 8;">
                            <Label text="Horas de Monitoria" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblHorasMonitoria" text="—" style="-fx-font-size: 22px; -fx-text-fill: #2980B9;"/>
                        </VBox>
                    </HBox>

                    <!-- Tabela detalhada -->
                    <Label text="Detalhamento:" style="-fx-font-weight: bold;"/>
                    <TableView fx:id="tabelaRelatorio" VBox.vgrow="ALWAYS" prefHeight="220">
                        <columns>
                            <TableColumn fx:id="colRelAluno" text="Aluno" prefWidth="180"/>
                            <TableColumn fx:id="colRelAssunto" text="Assunto" prefWidth="220"/>
                            <TableColumn fx:id="colRelStatus" text="Presença" prefWidth="110"/>
                            <TableColumn fx:id="colRelData" text="Data" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>

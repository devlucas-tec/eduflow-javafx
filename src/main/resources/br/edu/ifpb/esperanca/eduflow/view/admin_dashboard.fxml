<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.esperanca.eduflow.controller.AdminDashBoardController"
            styleClass="dashboard-root"
            stylesheets="@./styles/eduflow.css">

    <top>
        <HBox styleClass="topbar, topbar-admin" alignment="CENTER_LEFT" spacing="12">
            <VBox>
                <Label text="EduFlow" styleClass="topbar-title"/>
                <Label text="Painel Administrativo" styleClass="topbar-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblBemVindo" styleClass="user-badge"/>
            <Button text="Sair" onAction="#handleLogout" styleClass="btn-sair"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-area" VBox.vgrow="ALWAYS">
            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
                     styleClass="main-container" VBox.vgrow="ALWAYS">

                <!-- Aba 1: Disciplinas -->

                <Tab text="Disciplinas">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">

                            <!-- Card: Catálogo -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Catálogo de disciplinas" styleClass="label-section"/>
                                <TableView fx:id="tabelaDisciplinas" prefHeight="280" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colNome"     text="Nome"     prefWidth="250"/>
                                        <TableColumn fx:id="colCodigo"   text="Código"   prefWidth="120"/>
                                        <TableColumn fx:id="colSemestre" text="Semestre" prefWidth="120"/>
                                    </columns>
                                </TableView>
                            </VBox>

                            <!-- Card: Cadastrar nova disciplina -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Cadastrar nova disciplina" styleClass="label-section"/>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Nome" styleClass="field-label"/>
                                        <TextField fx:id="txtNomeDisciplina" promptText="Nome da disciplina"
                                                   styleClass="text-field"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Código" styleClass="field-label"/>
                                        <TextField fx:id="txtCodigoDisciplina" promptText="Ex: APS101"
                                                   prefWidth="140" styleClass="text-field"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Semestre" styleClass="field-label"/>
                                        <TextField fx:id="txtSemestreDisciplina" promptText="Ex: 2026.1"
                                                   prefWidth="130" styleClass="text-field"/>
                                    </VBox>
                                    <VBox spacing="5" alignment="BOTTOM_LEFT">
                                        <Label text=" " styleClass="field-label"/>
                                        <HBox spacing="8">
                                            <Button text="Cadastrar"
                                                    onAction="#handleCadastrarDisciplina"
                                                    styleClass="btn-accent"/>
                                            <Button text="Excluir Selecionada"
                                                    onAction="#handleExcluirDisciplina"
                                                    styleClass="btn-danger"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                <Text fx:id="errorMessage"   styleClass="label-error"   visible="false"/>
                                <Text fx:id="successMessage" styleClass="label-success" visible="false"/>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- Aba 2: Usuários -->
                <Tab text="Usuários">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">

                            <!-- Card: Filtros -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Filtrar usuários" styleClass="label-section"/>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <VBox spacing="5">
                                        <Label text="Perfil" styleClass="field-label"/>
                                        <ComboBox fx:id="filtroRole" prefWidth="160" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Status" styleClass="field-label"/>
                                        <ComboBox fx:id="filtroStatus" prefWidth="140" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" alignment="BOTTOM_LEFT">
                                        <Label text=" " styleClass="field-label"/>
                                        <HBox spacing="8">
                                            <Button text="Filtrar"  onAction="#handleFiltrarUsuarios" styleClass="btn-primary"/>
                                            <Button text="Limpar"   onAction="#handleLimparFiltros"   styleClass="btn-secondary"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <!-- Card: Lista + ações -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Lista de usuários" styleClass="label-section"/>
                                <TableView fx:id="tabelaUsuarios" VBox.vgrow="ALWAYS" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colUsuarioNome"      text="Nome"      prefWidth="180"/>
                                        <TableColumn fx:id="colUsuarioEmail"     text="E-mail"    prefWidth="200"/>
                                        <TableColumn fx:id="colUsuarioMatricula" text="Matrícula" prefWidth="100"/>
                                        <TableColumn fx:id="colUsuarioRole"      text="Perfil"    prefWidth="120"/>
                                        <TableColumn fx:id="colUsuarioStatus"    text="Status"    prefWidth="90"/>
                                    </columns>
                                </TableView>

                                <HBox spacing="20" alignment="TOP_LEFT">
                                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                                        <Label text="▸  Alterar perfil do usuário selecionado" styleClass="label-section"/>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <VBox spacing="5">
                                                <Label text="Novo perfil" styleClass="field-label"/>
                                                <ComboBox fx:id="novoRole" prefWidth="180" styleClass="combo-box"/>
                                            </VBox>
                                            <VBox spacing="5" alignment="BOTTOM_LEFT">
                                                <Label text=" " styleClass="field-label"/>
                                                <Button text="Aplicar Perfil"
                                                        onAction="#handleAlterarRole"
                                                        styleClass="btn-primary"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                    <VBox spacing="8">
                                        <Label text="▸  Status da conta" styleClass="label-section"/>
                                        <VBox spacing="5" alignment="BOTTOM_LEFT">
                                            <Label text=" " styleClass="field-label"/>
                                            <Button fx:id="btnToggleStatus"
                                                    text="Habilitar / Desabilitar"
                                                    onAction="#handleToggleStatus"
                                                    styleClass="btn-danger"/>
                                        </VBox>
                                    </VBox>
                                </HBox>
                                <Text fx:id="errorUsuario"   styleClass="label-error"   visible="false"/>
                                <Text fx:id="successUsuario" styleClass="label-success" visible="false"/>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- Aba 3: Professores -->
                <Tab text="Professores">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">

                            <!-- Card: Lista de professores -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Vínculo Professor ↔ Disciplina" styleClass="label-section"/>
                                <Label text="Selecione um professor:" styleClass="field-label"/>
                                <TableView fx:id="tabelaProfessores" prefHeight="200" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colProfNome"      text="Nome"      prefWidth="220"/>
                                        <TableColumn fx:id="colProfEmail"     text="E-mail"    prefWidth="220"/>
                                        <TableColumn fx:id="colProfMatricula" text="Matrícula" prefWidth="120"/>
                                        <TableColumn fx:id="colProfStatus"    text="Status"    prefWidth="80"/>
                                    </columns>
                                </TableView>
                            </VBox>

                            <!-- Card: Vínculo disciplinas -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Disciplinas vinculadas ao professor selecionado" styleClass="label-section"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Disciplina" styleClass="field-label"/>
                                        <ComboBox fx:id="comboDisciplinaVinculo"
                                                  maxWidth="Infinity" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" alignment="BOTTOM_LEFT">
                                        <Label text=" " styleClass="field-label"/>
                                        <HBox spacing="8">
                                            <Button text="Vincular"             onAction="#handleVincularDisciplina"  styleClass="btn-accent"/>
                                            <Button text="Desvincular Selecionada" onAction="#handleDesvincularDisciplina" styleClass="btn-danger"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                <TableView fx:id="tabelaDisciplinasProfessor" prefHeight="180" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colDPNome"     text="Disciplina" prefWidth="280"/>
                                        <TableColumn fx:id="colDPCodigo"   text="Código"     prefWidth="130"/>
                                        <TableColumn fx:id="colDPSemestre" text="Semestre"   prefWidth="130"/>
                                    </columns>
                                </TableView>
                                <Text fx:id="errorProfessor"   styleClass="label-error"   visible="false"/>
                                <Text fx:id="successProfessor" styleClass="label-success" visible="false"/>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- Aba 4: Monitores -->
                <Tab text="Monitores">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">

                            <!-- Card: Lista de monitores -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Vínculo Monitor ↔ Disciplina" styleClass="label-section"/>
                                <Label text="Selecione um monitor:" styleClass="field-label"/>
                                <TableView fx:id="tabelaMonitores" prefHeight="200" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colMonitorNome"      text="Nome"      prefWidth="220"/>
                                        <TableColumn fx:id="colMonitorEmail"     text="E-mail"    prefWidth="220"/>
                                        <TableColumn fx:id="colMonitorMatricula" text="Matrícula" prefWidth="120"/>
                                        <TableColumn fx:id="colMonitorStatus"    text="Status"    prefWidth="80"/>
                                    </columns>
                                </TableView>
                            </VBox>

                            <!-- Card: Vínculo disciplina -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Disciplina vinculada ao monitor (máx. 1)" styleClass="label-section"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Disciplina" styleClass="field-label"/>
                                        <ComboBox fx:id="comboDisciplinaMonitor"
                                                  maxWidth="Infinity" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" alignment="BOTTOM_LEFT">
                                        <Label text=" " styleClass="field-label"/>
                                        <HBox spacing="8">
                                            <Button text="Vincular"    onAction="#handleVincularMonitor"   styleClass="btn-accent"/>
                                            <Button text="Desvincular" onAction="#handleDesvincularMonitor" styleClass="btn-danger"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                <TableView fx:id="tabelaDisciplinasMonitor" prefHeight="180" styleClass="table-view" >
                                    <columns>
                                        <TableColumn fx:id="colDMNome"     text="Disciplina" prefWidth="280"/>
                                        <TableColumn fx:id="colDMCodigo"   text="Código"     prefWidth="130"/>
                                        <TableColumn fx:id="colDMSemestre" text="Semestre"   prefWidth="130"/>
                                    </columns>
                                </TableView>
                                <Text fx:id="errorMonitor"   styleClass="label-error"   visible="false"/>
                                <Text fx:id="successMonitor" styleClass="label-success" visible="false"/>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- Aba 5: Calendários -->
                <Tab text="Calendários">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">

                            <!-- Card: Filtro + tabela de aulas -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Filtrar por professor" styleClass="label-section"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Professor" styleClass="field-label"/>
                                        <ComboBox fx:id="comboProfessor" maxWidth="Infinity" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" alignment="BOTTOM_LEFT">
                                        <Label text=" " styleClass="field-label"/>
                                        <HBox spacing="8">
                                            <Button text="Ver Calendário" onAction="#handleCarregarCalendario" styleClass="btn-primary"/>
                                            <Button text="Ver Todos"      onAction="#handleVerTodasAulas"      styleClass="btn-secondary"/>
                                        </HBox>
                                    </VBox>
                                </HBox>

                                <Label text="▸  Aulas cadastradas" styleClass="label-section"/>
                                <TableView fx:id="tabelaAulas" prefHeight="220" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colAulaProfessor"    text="Professor"    prefWidth="150"/>
                                        <TableColumn fx:id="colAulaData"         text="Data/Hora"    prefWidth="150"/>
                                        <TableColumn fx:id="colAulaDisciplina"   text="Disciplina"   prefWidth="160"/>
                                        <TableColumn fx:id="colAulaTipo"         text="Tipo"         prefWidth="90"/>
                                        <TableColumn fx:id="colAulaJustificativa" text="Justificativa" prefWidth="220"/>
                                    </columns>
                                </TableView>
                            </VBox>

                            <!-- Card: Adicionar / Editar aula -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Adicionar / Editar aula" styleClass="label-section"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <VBox spacing="5">
                                        <Label text="Data e Hora" styleClass="field-label"/>
                                        <TextField fx:id="txtAulaData" promptText="dd/MM/yyyy HH:mm"
                                                   prefWidth="160" styleClass="text-field"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Tipo" styleClass="field-label"/>
                                        <ComboBox fx:id="comboTipoAula" prefWidth="130" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Disciplina" styleClass="field-label"/>
                                        <ComboBox fx:id="comboDisciplinaAula" maxWidth="Infinity" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Justificativa (opcional)" styleClass="field-label"/>
                                        <TextField fx:id="txtJustificativa" promptText="Somente para reposições"
                                                   styleClass="text-field"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="8">
                                    <Button text="Adicionar Aula"     onAction="#handleAdicionarAula"      styleClass="btn-accent"/>
                                    <Button text="Salvar Edição"      onAction="#handleEditarAula"          styleClass="btn-primary"/>
                                    <Button text="Remover Selecionada" onAction="#handleRemoverAula"        styleClass="btn-danger"/>
                                    <Button text="Limpar Seleção"     onAction="#handleLimparSelecaoAula"   styleClass="btn-neutral"/>
                                </HBox>
                                <Text fx:id="errorCalendario"   styleClass="label-error"   visible="false"/>
                                <Text fx:id="successCalendario" styleClass="label-success" visible="false"/>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </VBox>
    </center>
</BorderPane>
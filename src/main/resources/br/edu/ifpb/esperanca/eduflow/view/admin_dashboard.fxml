<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.esperanca.eduflow.controller.AdminDashBoardController"
            style="-fx-background-color: #F0F4F8;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2C3E50; -fx-padding: 15;">
            <Label fx:id="lblBemVindo" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Sair" onAction="#handleLogout"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 5;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <Label text="Catálogo de Disciplinas" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <TableView fx:id="tabelaDisciplinas" prefHeight="300" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="250"/>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="120"/>
                    <TableColumn fx:id="colSemestre" text="Semestre" prefWidth="120"/>
                </columns>
            </TableView>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtNomeDisciplina" promptText="Nome da disciplina" prefWidth="220"/>
                <TextField fx:id="txtCodigoDisciplina" promptText="Código (ex: APS101)" prefWidth="140"/>
                <TextField fx:id="txtSemestreDisciplina" promptText="Semestre (ex: 2026.1)" prefWidth="140"/>
                <Button text="Cadastrar" onAction="#handleCadastrarDisciplina"
                        style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-background-radius: 5;"/>
                <Button text="Excluir Selecionada" onAction="#handleExcluirDisciplina"
                        style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 5;"/>
            </HBox>
            <Text fx:id="errorMessage" fill="RED" visible="false"/>
            <Text fx:id="successMessage" fill="GREEN" visible="false"/>
        </VBox>
    </center>
</BorderPane>

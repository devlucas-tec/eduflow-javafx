<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.esperanca.eduflow.controller.ProfessorDashboardController"
            styleClass="dashboard-root"
            stylesheets="@./styles/eduflow.css">

    <top>
        <HBox styleClass="topbar, topbar-professor" alignment="CENTER_LEFT" spacing="12">
            <VBox>
                <Label text="EduFlow" styleClass="topbar-title"/>
                <Label text="Painel do Professor" styleClass="topbar-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblBemVindo" styleClass="user-badge"/>
            <Button text="Sair" onAction="#handleLogout" styleClass="btn-sair"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-area" VBox.vgrow="ALWAYS">
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="main-container" VBox.vgrow="ALWAYS">

                <!-- Aba 1: Minhas Disciplinas -->
                <Tab text="Minhas Disciplinas">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Disciplinas vinculadas" styleClass="label-section"/>
                                <TableView fx:id="tabelaDisciplinas" prefHeight="350" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colDisciplinaNome"     text="Nome"     prefWidth="280"/>
                                        <TableColumn fx:id="colDisciplinaCodigo"   text="Código"   prefWidth="130"/>
                                        <TableColumn fx:id="colDisciplinaSemestre" text="Semestre" prefWidth="130"/>
                                    </columns>
                                </TableView>
                                <Text fx:id="msgDisciplinas" styleClass="label-error" visible="false"/>
                            </VBox>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- Aba 2: Calendário de Aulas -->
                <Tab text="Calendário de Aulas">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">

                            <!-- Card: Filtro + tabela -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Calendário de aulas" styleClass="label-section"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <VBox spacing="5">
                                        <Label text="Disciplina" styleClass="field-label"/>
                                        <ComboBox fx:id="comboDisciplinaCalendario"
                                                  prefWidth="220" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" alignment="BOTTOM_LEFT">
                                        <Label text=" " styleClass="field-label"/>
                                        <HBox spacing="8">
                                            <Button text="Filtrar" onAction="#handleFiltrarAulas" styleClass="btn-primary"/>
                                            <Button text="Ver Todas" onAction="#handleVerTodasMinhasAulas" styleClass="btn-secondary"/>
                                        </HBox>
                                    </VBox>
                                    <VBox alignment="BOTTOM_LEFT">
                                        <Label fx:id="lblCargaHoraria" text="" styleClass="label-section"/>
                                    </VBox>
                                </HBox>
                                <TableView fx:id="tabelaMinhasAulas" prefHeight="220" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colCalData"          text="Data/Hora"    prefWidth="150"/>
                                        <TableColumn fx:id="colCalDisciplina"    text="Disciplina"   prefWidth="180"/>
                                        <TableColumn fx:id="colCalTipo"          text="Tipo"         prefWidth="100"/>
                                        <TableColumn fx:id="colCalJustificativa" text="Justificativa" prefWidth="250"/>
                                    </columns>
                                </TableView>
                            </VBox>

                            <!-- Card: Adicionar / Editar aula -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Adicionar / Editar aula" styleClass="label-section"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <VBox spacing="5">
                                        <Label text="Data e Hora" styleClass="field-label"/>
                                        <TextField fx:id="txtCalData" promptText="dd/MM/yyyy HH:mm"
                                                   prefWidth="160" styleClass="text-field"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Tipo" styleClass="field-label"/>
                                        <ComboBox fx:id="comboCalTipo" prefWidth="120" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Disciplina" styleClass="field-label"/>
                                        <ComboBox fx:id="comboCalDisciplina" maxWidth="Infinity" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Justificativa (opcional)" styleClass="field-label"/>
                                        <TextField fx:id="txtCalJustificativa" promptText="Justificativa..."
                                                   styleClass="text-field"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="8">
                                    <Button text="Adicionar"           onAction="#handleAdicionarMinhaAula" styleClass="btn-accent"/>
                                    <Button text="Salvar Edição"       onAction="#handleEditarMinhaAula"    styleClass="btn-primary"/>
                                    <Button text="Remover Selecionada" onAction="#handleRemoverMinhaAula"   styleClass="btn-danger"/>
                                    <Button text="Limpar"              onAction="#handleLimparCalendario"   styleClass="btn-neutral"/>
                                </HBox>
                                <Text fx:id="errorCalendario"   styleClass="label-error"   visible="false"/>
                                <Text fx:id="successCalendario" styleClass="label-success" visible="false"/>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- Aba 3: Validação de Atendimentos -->
                <Tab text="Validação de Atendimentos">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Atendimentos registrados pelo monitor" styleClass="label-section"/>
                                <TableView fx:id="tabelaParaValidar" prefHeight="320" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colAluno"         text="Aluno"              prefWidth="140"/>
                                        <TableColumn fx:id="colAssunto"       text="Assunto"             prefWidth="180"/>
                                        <TableColumn fx:id="colPresenca"      text="Presença"            prefWidth="100"/>
                                        <TableColumn fx:id="colConteudo"      text="Conteúdo Trabalhado" prefWidth="200"/>
                                        <TableColumn fx:id="colDataRegistro"  text="Registrado em"       prefWidth="130"/>
                                        <TableColumn fx:id="colStatus"        text="Status"              prefWidth="100"/>
                                        <TableColumn fx:id="colJustificativa" text="Justificativa"       prefWidth="180"/>
                                    </columns>
                                </TableView>
                                <HBox spacing="10">
                                    <Button text="✅ Validar Atendimento"  onAction="#handleValidar"  styleClass="btn-accent"/>
                                    <Button text="❌ Rejeitar Atendimento" onAction="#handleRejeitar" styleClass="btn-danger"/>
                                </HBox>
                                <Text fx:id="errorMessage"   styleClass="label-error"   visible="false"/>
                                <Text fx:id="successMessage" styleClass="label-success" visible="false"/>
                            </VBox>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- Aba 4: Monitores -->
                <Tab text="Monitores">
                    <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                        <VBox spacing="16" style="-fx-padding: 20;">

                            <!-- Card: Filtro + sessões -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Agenda dos monitores" styleClass="label-section"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <VBox spacing="5">
                                        <Label text="Disciplina" styleClass="field-label"/>
                                        <ComboBox fx:id="comboDisciplinaMonitor" prefWidth="220" styleClass="combo-box"/>
                                    </VBox>
                                    <VBox spacing="5" alignment="BOTTOM_LEFT">
                                        <Label text=" " styleClass="field-label"/>
                                        <Button text="Carregar Agenda" onAction="#handleCarregarAgendaMonitor" styleClass="btn-purple"/>
                                    </VBox>
                                </HBox>
                                <Label text="▸  Sessões de monitoria" styleClass="label-section"/>
                                <TableView fx:id="tabelaAgendasMonitor" prefHeight="200" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colMonNome"          text="Monitor"                      prefWidth="160"/>
                                        <TableColumn fx:id="colMonHorario"       text="Data/Hora"                    prefWidth="160"/>
                                        <TableColumn fx:id="colMonLocal"         text="Local / Link"                 prefWidth="160"/>
                                        <TableColumn fx:id="colMonStatus"        text="Status"                       prefWidth="90"/>
                                        <TableColumn fx:id="colMonJustificativa" text="Justificativa do Cancelamento" prefWidth="240"/>
                                    </columns>
                                </TableView>
                            </VBox>

                            <!-- Card: Agendamentos da sessão -->
                            <VBox spacing="10" styleClass="section-card">
                                <Label text="▸  Agendamentos da sessão selecionada" styleClass="label-section"/>
                                <TableView fx:id="tabelaAgendamentosMonitor" prefHeight="180" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colAgmAluno"         text="Aluno"        prefWidth="180"/>
                                        <TableColumn fx:id="colAgmAssunto"       text="Assunto"       prefWidth="220"/>
                                        <TableColumn fx:id="colAgmStatus"        text="Status"        prefWidth="130"/>
                                        <TableColumn fx:id="colAgmJustificativa" text="Justificativa" prefWidth="220"/>
                                    </columns>
                                </TableView>
                                <Text fx:id="errorMonitor" styleClass="label-error" visible="false"/>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </VBox>
    </center>
</BorderPane>
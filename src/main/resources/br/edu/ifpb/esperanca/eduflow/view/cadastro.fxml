<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="15.0" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.ifpb.esperanca.eduflow.controller.CadastroController"
      style="-fx-background-color: #F0F4F8;">
    <padding><Insets bottom="30" left="40" right="40" top="30"/></padding>

    <Label text="Cadastro - EduFlow" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2A4D69;"/>

    <TextField fx:id="txtNome" promptText="Nome completo" maxWidth="300"/>
    <TextField fx:id="txtEmail" promptText="E-mail institucional" maxWidth="300"/>
    <TextField fx:id="txtMatricula" promptText="Matrícula" maxWidth="300"/>
    <PasswordField fx:id="txtSenha" promptText="Senha (mín. 6 caracteres)" maxWidth="300"/>
    <PasswordField fx:id="txtConfirmaSenha" promptText="Confirmar senha" maxWidth="300"/>

    <Button text="Cadastrar" onAction="#handleCadastrar"
            style="-fx-background-color: #2A4D69; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5;"/>
    <Hyperlink text="Voltar para Login" onAction="#handleVoltarLogin"/>

    <Text fx:id="errorMessage" fill="RED" visible="false"/>
    <Text fx:id="successMessage" fill="GREEN" visible="false"/>
</VBox>

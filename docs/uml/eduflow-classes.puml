@startuml EduFlow - Diagrama de Classes

!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

skinparam class {
    BackgroundColor #F8F8F8
    BorderColor #555555
    BorderThickness 1.5
    HeaderBackgroundColor #4A4A8A
    HeaderFontColor #FFFFFF
    HeaderFontStyle bold
    HeaderFontSize 13
    AttributeFontSize 11
    StereotypeFontSize 10
    ArrowColor #444444
    ArrowThickness 1.5
}

skinparam note {
    BackgroundColor #FFFBE6
    BorderColor #CCAA00
    FontSize 10
}

skinparam package {
    BackgroundColor #FAFAFA
    BorderColor #888888
    BorderThickness 1
    FontSize 12
    FontStyle bold
}

' ============================================================
' LAYOUT: left to right para melhor uso horizontal da tela
' ============================================================
left to right direction

' ============================================================
' PACKAGE: domain.enums  (canto superior esquerdo)
' ============================================================
package "domain.enums" #EEF0FF {

    enum Role <<enum>> {
        ALUNO
        MONITOR
        PROFESSOR
        ADMINISTRADOR
    }

    enum StatusAgendamento <<enum>> {
        PENDENTE
        CONFIRMADO
        CANCELADO_ALUNO
        CANCELADO_MONITOR
        REALIZADO
        FALTOU
        VALIDADO
    }
}

' ============================================================
' PACKAGE: domain.exceptions
' ============================================================
package "domain.exceptions" #FFF0F0 {

    class BusinessException <<exception>> {
        + message : String
        + BusinessException(message: String)
    }

    class ValidationException <<exception>> {
        + message : String
        + ValidationException(message: String)
    }
}

' ============================================================
' PACKAGE: domain.entities
' ============================================================
package "domain.entities" #F0F4FF {

    abstract class Usuario <<abstract>> {
        - id : Long
        - nome : String
        - email : String
        - senhaHash : String
        - matricula : String
        - ativo : boolean
        # role : Role
        ..
        + editarPerfil(nome: String, email: String) : void
        + getRole() : Role
        + isAtivo() : boolean
    }

    class Aluno {
        - faltasAcumuladas : int
        - bloqueadoAte : LocalDate
        ~ {static} LIMITE_FALTAS : int = 3
        ~ {static} DIAS_BLOQUEIO : int = 7
        ..
        + estaBloqueado() : boolean
        + registrarFalta() : void
        + resetarFaltas() : void
        + podeAgendar(agenda: Agenda) : boolean
        + temConflito(ativos: List, inicio: LDT, fim: LDT) : boolean
        + agendarMonitoria(agenda: Agenda, ativos: List, assunto: String) : Agendamento
    }

    class Monitor {
        - disciplinasVinculadas : List<Disciplina>
        - agendas : List<Agenda>
        ..
        + estaVinculadoA(disciplina: Disciplina) : boolean
        + cadastrarAgenda(agenda: Agenda, disciplina: Disciplina) : Agenda
        + agendarMonitoria(agenda: Agenda, ativos: List, assunto: String) : Agendamento
        + registrarAtendimento(agendamento: Agendamento, presenca: boolean, conteudo: String) : Atendimento
    }

    class Professor {
        - disciplinas : List<Disciplina>
        ..
        + estaVinculadoA(disciplina: Disciplina) : boolean
        + validarAtendimento(agendamento: Agendamento, disciplina: Disciplina) : void
    }

    class Administrador {
    }

    class Disciplina {
        - id : Long
        - nome : String
        - codigo : String
        ..
        + getId() : Long
        + getNome() : String
        + getCodigo() : String
    }

    class Agenda {
        - id : Long
        - dataHoraInicio : LocalDateTime
        - dataHoraFim : LocalDateTime
        - local : String
        - link : String
        - vagasTotais : int
        - vagasOcupadas : int
        - cancelada : boolean
        - justificativa : String
        - monitorNome : String
        ..
        + getVagasDisponiveis() : int
        + ocuparVaga() : void
        + liberarVaga() : void
    }

    class Agendamento {
        - id : Long
        - assunto : String
        - dataHoraSolicitacao : LocalDateTime
        - status : StatusAgendamento
        - justificativa : String
        ..
        + cancelarPeloAluno() : void
        + cancelarPeloMonitor(justificativa: String) : void
        + podeCancelarComoMonitor() : boolean
    }

    class Atendimento {
        - id : Long
        - presenca : boolean
        - conteudoTrabalhado : String
        - dataHoraRegistro : LocalDateTime
        ..
        + isPresenca() : boolean
        + getConteudoTrabalhado() : String
    }

    class Aula {
        - id : Long
        - diaSemana : String
        - horaInicio : LocalTime
        - horaFim : LocalTime
        ..
        + getDiaSemana() : String
        + getHoraInicio() : LocalTime
        + getHoraFim() : LocalTime
    }
}

' ============================================================
' PACKAGE: repository
' ============================================================
package "repository" #F0FFF4 {

    class ConectionFactory <<singleton>> {
        - {static} connection : Connection
        - {static} envVars : Map<String, String>
        ..
        + {static} getConnection() : Connection
        - {static} carregarEnv() : void
    }

    class UsuarioRepository {
        ..
        + buscarPorEmail(email: String) : Optional<Usuario>
        + buscarPorId(id: Long) : Optional<Usuario>
        + salvar(usuario: Usuario) : Usuario
        + atualizar(usuario: Usuario) : void
    }

    class AgendaRepository {
        ..
        + buscarPorId(id: Long) : Optional<Agenda>
        + listarPorMonitor(monitorId: Long) : List<Agenda>
        + listarDisponiveisPorDisciplina(discId: Long) : List<Agenda>
        + salvar(agenda: Agenda) : Agenda
        + atualizarVagas(agenda: Agenda) : void
        + cancelarAgenda(id: Long) : void
    }

    class AgendamentoRepository {
        ..
        + salvar(agendamento: Agendamento) : Agendamento
        + buscarPorId(id: Long) : Optional<Agendamento>
        + listarAtivosPorAluno(alunoId: Long) : List<Agendamento>
        + listarTodosPorAluno(alunoId: Long) : List<Agendamento>
        + listarPorAgenda(agendaId: Long) : List<Agendamento>
        + listarParaValidacaoPorMonitor(monitorId: Long) : List<Agendamento>
        + cancelarAgendamento(id: Long, status: StatusAgendamento, just: String) : void
        + atualizarStatus(id: Long, status: StatusAgendamento) : void
    }

    class AtendimentoRepository {
        ..
        + salvar(atendimento: Atendimento) : Atendimento
        + listarParaValidacaoPorProfessor(profId: Long) : List<Atendimento>
        + deletarPorAgendamento(agendamentoId: Long) : void
    }

    class DisciplinaRepository {
        ..
        + listarTodas() : List<Disciplina>
        + buscarPorId(id: Long) : Optional<Disciplina>
        + salvar(disciplina: Disciplina) : Disciplina
        + deletar(id: Long) : void
    }

    class MonitorDisciplinaRepository {
        ..
        + vincular(monitorId: Long, discId: Long) : void
        + desvincular(monitorId: Long, discId: Long) : void
        + listarDisciplinasPorMonitor(monitorId: Long) : List<Disciplina>
        + listarMonitoresPorDisciplina(discId: Long) : List<Monitor>
    }

    class ProfessorDisciplinaRepository {
        ..
        + vincular(profId: Long, discId: Long) : void
        + listarDisciplinasPorProfessor(profId: Long) : List<Disciplina>
        + listarProfessoresPorDisciplina(discId: Long) : List<Professor>
    }

    class AlunoDisciplinaRepository {
        ..
        + matricular(alunoId: Long, discId: Long) : void
        + listarDisciplinasPorAluno(alunoId: Long) : List<Disciplina>
    }

    class AulaRepository {
        ..
        + salvar(aula: Aula) : Aula
        + listarPorDisciplina(discId: Long) : List<Aula>
        + deletar(id: Long) : void
    }
}

' ============================================================
' PACKAGE: service
' ============================================================
package "service" #FFF8F0 {

    class SessionManager <<singleton>> {
        - {static} instance : SessionManager
        - usuarioLogado : Usuario
        ..
        + {static} getInstance() : SessionManager
        + login(usuario: Usuario) : void
        + logout() : void
        + getUsuarioLogado() : Usuario
        + isLogado() : boolean
    }

    class UsuarioService {
        - usuarioRepository : UsuarioRepository
        ..
        + autenticar(email: String, senha: String) : Usuario
        + cadastrar(usuario: Usuario) : Usuario
        + editarPerfil(id: Long, nome: String, email: String) : void
        + ativar(id: Long) : void
        + desativar(id: Long) : void
    }

    class AgendaService {
        - agendaRepository : AgendaRepository
        ..
        + listarPorMonitor(monitorId: Long) : List<Agenda>
        + listarDisponiveisPorDisciplina(discId: Long) : List<Agenda>
        + criarAgenda(agenda: Agenda) : Agenda
        + cancelarAgenda(agendaId: Long, justificativa: String) : void
    }

    class AgendamentoService {
        - agendamentoRepository : AgendamentoRepository
        - agendaRepository : AgendaRepository
        - atendimentoRepository : AtendimentoRepository
        ..
        + agendarMonitoria(aluno: Aluno, agenda: Agenda, assunto: String) : Agendamento
        + cancelarPeloAluno(agendamento: Agendamento, aluno: Aluno) : void
        + cancelarPeloMonitor(agendamento: Agendamento, justificativa: String) : void
        + registrarAtendimento(monitor: Monitor, agendamento: Agendamento, presenca: boolean, conteudo: String) : Atendimento
        + validarAtendimento(agendamento: Agendamento, professor: Professor) : void
        + rejeitarAtendimento(agendamento: Agendamento) : void
        + listarPorAgenda(agendaId: Long) : List<Agendamento>
        + listarAtivosPorAluno(alunoId: Long) : List<Agendamento>
        + listarParaValidacao(monitorId: Long) : List<Agendamento>
    }

    class DisciplinaService {
        - disciplinaRepository : DisciplinaRepository
        ..
        + listarTodas() : List<Disciplina>
        + buscarPorId(id: Long) : Optional<Disciplina>
        + cadastrar(disciplina: Disciplina) : Disciplina
        + remover(id: Long) : void
    }

    class RelatorioService {
        - agendamentoRepository : AgendamentoRepository
        ..
        + totalAtendimentos(monitorId: Long) : long
        + totalFaltas(monitorId: Long) : long
        + horasDeMonitoria(monitorId: Long) : long
        + listarAtendimentosFinalizados(monitorId: Long) : List<Agendamento>
    }

    class MonitorDisciplinaService {
        - monitorDisciplinaRepository : MonitorDisciplinaRepository
        ..
        + vincular(monitorId: Long, discId: Long) : void
        + desvincular(monitorId: Long, discId: Long) : void
        + listarDisciplinasPorMonitor(monitorId: Long) : List<Disciplina>
    }

    class ProfessorDisciplinaService {
        - professorDisciplinaRepository : ProfessorDisciplinaRepository
        ..
        + vincular(profId: Long, discId: Long) : void
        + listarDisciplinasPorProfessor(profId: Long) : List<Disciplina>
    }

    class AlunoDisciplinaService {
        - alunoDisciplinaRepository : AlunoDisciplinaRepository
        ..
        + matricular(alunoId: Long, discId: Long) : void
        + listarDisciplinasPorAluno(alunoId: Long) : List<Disciplina>
    }

    class AulaService {
        - aulaRepository : AulaRepository
        ..
        + salvar(aula: Aula) : Aula
        + listarPorDisciplina(discId: Long) : List<Aula>
        + deletar(id: Long) : void
    }
}

' ============================================================
' RELACIONAMENTOS: Herança
' ============================================================
Usuario <|-- Aluno
Usuario <|-- Professor
Usuario <|-- Administrador
Aluno   <|-- Monitor

' ============================================================
' RELACIONAMENTOS: Associações domain
' ============================================================
Usuario        "1"  o--  "1"   Role               : role >
Agendamento    "1"  o--  "1"   StatusAgendamento  : status >

Agenda         "*"  --o  "1"   Monitor            : pertence a >
Agenda         "*"  --o  "1"   Disciplina         : referente a >
Agendamento    "*"  --o  "1"   Aluno              : realizado por >
Agendamento    "*"  --o  "1"   Agenda             : reserva em >
Atendimento    "0..1" *-- "1"  Agendamento        : registra >
Aula           "*"  --o  "1"   Disciplina         : grade de >

Monitor        "*"  o--  "*"   Disciplina         : vinculado a >
Professor      "*"  o--  "*"   Disciplina         : responsável por >

' ============================================================
' RELACIONAMENTOS: Repositórios -> ConectionFactory
' ============================================================
UsuarioRepository             ..>  ConectionFactory           : <<usa>>
AgendaRepository              ..>  ConectionFactory           : <<usa>>
AgendamentoRepository         ..>  ConectionFactory           : <<usa>>
AtendimentoRepository         ..>  ConectionFactory           : <<usa>>
DisciplinaRepository          ..>  ConectionFactory           : <<usa>>
MonitorDisciplinaRepository   ..>  ConectionFactory           : <<usa>>
ProfessorDisciplinaRepository ..>  ConectionFactory           : <<usa>>
AlunoDisciplinaRepository     ..>  ConectionFactory           : <<usa>>
AulaRepository                ..>  ConectionFactory           : <<usa>>

' ============================================================
' RELACIONAMENTOS: Serviços -> Repositórios
' ============================================================
UsuarioService             ..>  UsuarioRepository              : <<usa>>
AgendaService              ..>  AgendaRepository               : <<usa>>
AgendamentoService         ..>  AgendamentoRepository          : <<usa>>
AgendamentoService         ..>  AgendaRepository               : <<usa>>
AgendamentoService         ..>  AtendimentoRepository          : <<usa>>
DisciplinaService          ..>  DisciplinaRepository           : <<usa>>
RelatorioService           ..>  AgendamentoRepository          : <<usa>>
MonitorDisciplinaService   ..>  MonitorDisciplinaRepository    : <<usa>>
ProfessorDisciplinaService ..>  ProfessorDisciplinaRepository  : <<usa>>
AlunoDisciplinaService     ..>  AlunoDisciplinaRepository      : <<usa>>
AulaService                ..>  AulaRepository                 : <<usa>>

' ============================================================
' RELACIONAMENTOS: Entidades -> Exceções
' ============================================================
Aluno       ..>  BusinessException : <<lança>>
Monitor     ..>  BusinessException : <<lança>>
Professor   ..>  BusinessException : <<lança>>
Agendamento ..>  BusinessException : <<lança>>

' ============================================================
' NOTAS com as Regras de Negócio (agrupadas por tema)
' ============================================================
note right of Aluno
  <b>RN01</b> – Conflito de horários (temConflito)
  <b>RN03</b> – Vagas disponíveis (podeAgendar)
  <b>RN04</b> – Bloqueio por faltas (3 faltas → 7 dias)
end note

note right of Monitor
  <b>RN06</b> – Registro obrigatório do atendimento
  <b>RN07</b> – Vínculo obrigatório à disciplina
  <b>RN08</b> – Auto-agendamento bloqueado
end note

note right of Professor
  <b>RN02</b> – Só o professor responsável
  pode validar horas do monitor
  <b>RN09</b> – Apenas VALIDADO conta no relatório
end note

note right of Agendamento
  <b>RN05</b> – Monitor só cancela com
  >= 2h de antecedência + justificativa
end note

note right of Agenda
  <b>RN10</b> – Local físico ou link de
  videoconferência obrigatório
end note

@enduml
